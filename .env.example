# GitHub PAT with repo scope (required for GraphQL API)
GITHUB_TOKEN=ghp_your_token_here

# Sentry webhook signing secret (required for HMAC verification)
SENTRY_CLIENT_SECRET=your_sentry_secret_here

# Slack incoming webhook URL
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00/B00/xxx

# Redis connection URL
REDIS_URL=redis://localhost:6379

# Sentry project slug → GitHub owner/repo mapping (comma-separated)
# Example: my-backend:acme/backend-api,my-frontend:acme/web-app
REPO_MAP=my-project:owner/repo

# Prefix to strip from Sentry file paths (container path → git-relative)
# Example: /usr/src/app/
PATH_STRIP_PREFIX=

# Fallback Git ref when Sentry release SHA is missing
DEFAULT_BRANCH=main

# Server configuration
PORT=8000
LOG_LEVEL=INFO
